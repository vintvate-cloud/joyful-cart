{
    "version": 2,
    "framework": "vite",
    "buildCommand": "npx prisma generate && npx vite build",
    "outputDirectory": "dist",
    "installCommand": "npm install",
    "functions": {
        "api/index.ts": {
            "maxDuration": 30,
            "includeFiles": "node_modules/.prisma/client/libquery_engine-*"
        }
    },
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api/index"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}